# Copy to .env and fill in. .env is gitignored; never commit real secrets.

# Cloud Postgres (Supabase session pooler — IPv4, handles dbt DDL).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# MintMCP agent identity (M2M client). Copy the two URLs VERBATIM from the admin
# UI — the token endpoint has two shapes and must not be derived from the MCP URL.
MINTMCP_TOKEN_URL=
MINTMCP_MCP_URL=
MINTMCP_CLIENT_ID=
MINTMCP_CLIENT_SECRET=

# Agent + judge models via OpenRouter.
OPENROUTER_API_KEY=
# FAULTLINE_MODEL=minimax/minimax-m3          # optional override (investigator)
# FAULTLINE_JUDGE_MODEL=openai/gpt-4o-mini    # optional override (LLM-as-judge)

# LangSmith tracing (agent-behavior view).
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=faultline
